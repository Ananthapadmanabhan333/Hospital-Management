# Environment Configuration
NODE_ENV=development
PORT=5000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hospital_cms
DB_USER=hospital_admin
DB_PASSWORD=your_secure_password_here
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=20

# JWT Secrets - Use strong random strings in production
JWT_ACCESS_SECRET=your_access_secret_min_64_chars_here_replace_in_production
JWT_REFRESH_SECRET=your_refresh_secret_min_64_chars_here_replace_in_production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Cookie Settings
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=Hospital CMS <noreply@hospitalcms.com>

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# Frontend URL
FRONTEND_URL=http://localhost:3000

# UHID Prefix
UHID_PREFIX=UHID
